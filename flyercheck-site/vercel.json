{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "flyercheck.io" }],
      "destination": "https://www.flyercheck.io/:path*",
      "permanent": true
    }
  ],
  "functions": {
    "api/analyze-flyer.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
