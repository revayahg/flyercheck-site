# Formspree form endpoint for contact form (e.g. https://formspree.io/f/XXXXXXX)
# If not set, the contact page shows a helpful message to email info@revayahg.com
VITE_FORMSPREE_ENDPOINT=

# Google Analytics 4 measurement ID (G-XXXXXXXXXX). Optional: defaults to legacy shared ID.
# Set to false to disable GA. Use a dedicated FlyerCheck property ID when ready.
VITE_GA_MEASUREMENT_ID=

# Public in the browser bundle — never put secrets here (no OpenAI keys, no service-role keys).
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
# Protect data with Supabase Row Level Security (RLS) in the dashboard, not by hiding the anon key.

# Server-only (Vercel → Project → Settings → Environment Variables; never commit real values):
# OPENAI_API_KEY=sk-...
# Optional: faster/cheaper vision model if the default times out on your plan (default: gpt-4o).
# OPENAI_VISION_MODEL=gpt-4o-mini

# Comma-separated list of allowed origins for /api/analyze-flyer CORS. If unset, defaults include
# https://www.flyercheck.io, https://flyercheck.io, localhost Vite ports, and VERCEL_URL (preview).
# Use * only in an emergency (allows any site to trigger your API from users’ browsers).
# ALLOWED_ORIGINS=https://www.flyercheck.io,https://flyercheck.io
